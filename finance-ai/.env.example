# ──────────────────────────────────────────────────────────────────────────────
# Finance AI Service — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and paste your actual key below.
# ──────────────────────────────────────────────────────────────────────────────

# ── Google Gemini API Key ─────────────────────────────────────────────────────
# Get your free key from: https://aistudio.google.com/app/apikey
# PASTE YOUR KEY BELOW:
GOOGLE_API_KEY=YOUR_GOOGLE_GEMINI_API_KEY_HERE

# ── Service Config ────────────────────────────────────────────────────────────
PORT=5001
FLASK_DEBUG=false
ALLOWED_ORIGINS=https://yourdomain.com

# ── Backend URL (for RabbitMQ consumer to push anomalies) ─────────────────────
BACKEND_URL=http://localhost:8080
RABBITMQ_HOST=localhost
RABBITMQ_USER=YOUR_PROD_RABBITMQ_USER
RABBITMQ_PASS=YOUR_STRONG_PROD_RABBITMQ_PASS
