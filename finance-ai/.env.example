# Finance AI Service - sample environment file
# Copy this file to .env and paste your actual keys locally.

# Gemini API
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# Optional backward-compatible alias
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_STATEMENT_MODEL=gemini-2.5-pro

# Internal API authentication
INTERNAL_API_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Service config
PORT=5001
FLASK_DEBUG=false
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
STATEMENT_LLM_FALLBACK=true

# Backend URL and RabbitMQ
BACKEND_URL=http://localhost:8080
RABBITMQ_HOST=localhost
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
