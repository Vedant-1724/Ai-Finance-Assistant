# AI Finance Assistant - sample environment file
# Copy this file to .env and fill in only the providers you want to enable.

# Core app
DB_USERNAME=postgres
DB_PASSWORD=
JWT_SECRET=
INTERNAL_API_KEY=
APP_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# AI service
GOOGLE_API_KEY=
AI_SERVICE_URL=http://localhost:5001
AI_SERVICE_API_KEY=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Email
MAIL_ENABLED=false
MAIL_EXPOSE_LINKS_WHEN_DISABLED=true
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=
MAIL_FROM=noreply@financeai.in

# Razorpay
# Leave these blank to keep online payments disabled.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Bank sync / Setu
# AUTO uses Setu if configured, otherwise the backend falls back to mock mode.
BANK_SYNC_PROVIDER=AUTO
SETU_BASE_URL=
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
SETU_CALLBACK_URL=http://localhost:8080/api/v1/setu/callback

# Monitoring / backups
GRAFANA_ADMIN_PASSWORD=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=
