# ──────────────────────────────────────────────────────────────────────────────
# AI Finance Assistant — Root Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and paste your actual keys below.
# These are used by docker-compose.yml and the backend application.yaml.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=YOUR_STRONG_DB_PASSWORD_HERE

# ── JWT Secret (change in production — use a 64+ char random string) ─────────
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_A_64_CHAR_RANDOM_STRING_HERE_12345678

# ── Google Gemini API Key ─────────────────────────────────────────────────────
# Get your free key from: https://aistudio.google.com/app/apikey
# PASTE YOUR KEY BELOW:
GOOGLE_API_KEY=YOUR_GOOGLE_GEMINI_API_KEY_HERE

# ── Razorpay Payment Gateway ─────────────────────────────────────────────────
# Get your keys from: https://dashboard.razorpay.com/app/keys
# PASTE YOUR KEYS BELOW:
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID_HERE
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET_HERE
RAZORPAY_WEBHOOK_SECRET=PASTE_YOUR_RAZORPAY_WEBHOOK_SECRET_HERE

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── Email (optional — set MAIL_ENABLED=true to activate) ─────────────────────
MAIL_ENABLED=false
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=your-sendgrid-api-key
MAIL_FROM=noreply@financeai.in

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production, replace with your actual domain (e.g. https://yourdomain.com)
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ── Microservice Auth ─────────────────────────────────────────────────────────
INTERNAL_API_KEY=YOUR_STRONG_RANDOM_KEY_HERE_123

# ── Metrics Monitoring ────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=YOUR_STRONG_GRAFANA_PASSWORD_HERE

# ── PostgreSQL Daily Backup (AWS S3) ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY_HERE
AWS_REGION=ap-south-1
S3_BUCKET=your-db-backup-bucket-name
