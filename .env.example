# ──────────────────────────────────────────────────────────────────────────────
# AI Finance Assistant — Root Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and paste your actual keys below.
# These are used by docker-compose.yml and the backend application.yaml.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=vedant

# ── JWT Secret (change in production — use a 64+ char random string) ─────────
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_A_64_CHAR_RANDOM_STRING_HERE_12345678

# ── Google Gemini API Key ─────────────────────────────────────────────────────
# Get your free key from: https://aistudio.google.com/app/apikey
# PASTE YOUR KEY BELOW:
GOOGLE_API_KEY=AIzaSyAW_SsLSkOBwtfZq35oahlMdUrDxTTtX0E

# ── Razorpay Payment Gateway ─────────────────────────────────────────────────
# Get your keys from: https://dashboard.razorpay.com/app/keys
# PASTE YOUR KEYS BELOW:
RAZORPAY_KEY_ID=rzp_test_SN7BpHweqt2xtJ
RAZORPAY_KEY_SECRET=ut8uqzyVmIFTVbFnfsKbi9jv
RAZORPAY_WEBHOOK_SECRET=PASTE_YOUR_RAZORPAY_WEBHOOK_SECRET_HERE

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ── Email (optional — set MAIL_ENABLED=true to activate) ─────────────────────
MAIL_ENABLED=false
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=your-sendgrid-api-key
MAIL_FROM=noreply@financeai.in

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
