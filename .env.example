# AI Finance Assistant - sample environment file
# Copy this file to .env and fill in only the providers you want to enable.

# Core app
DB_USERNAME=postgres
DB_PASSWORD=
JWT_SECRET=
INTERNAL_API_KEY=
APP_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# AI service
GEMINI_API_KEY=
# Optional backward-compatible alias if you still use the old variable name.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_STATEMENT_MODEL=gemini-2.5-pro
AI_SERVICE_URL=http://localhost:5001
AI_SERVICE_API_KEY=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_ERLANG_COOKIE=

# Bootstrap admin (used by Docker; local backend can also read admin.local.json)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_COMPANY=
BOOTSTRAP_ADMIN_PLAN=MAX
BOOTSTRAP_ADMIN_CURRENCY=INR

# Email
MAIL_ENABLED=false
MAIL_EXPOSE_LINKS_WHEN_DISABLED=true
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=
MAIL_FROM=noreply@financeai.in

# Razorpay
# Leave these blank to keep online payments disabled.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Bank sync / Setu
# AUTO uses Setu if configured, otherwise the backend falls back to mock mode.
BANK_SYNC_PROVIDER=AUTO
SETU_BASE_URL=
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
SETU_CALLBACK_URL=http://localhost:8080/api/v1/setu/callback

# Monitoring / backups
GRAFANA_ADMIN_PASSWORD=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=

# Cloud deployment (leave blank for local Docker development)
DATABASE_URL=
REDIS_URL=
CLOUDAMQP_URL=
VITE_API_BASE_URL=

