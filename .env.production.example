# ──────────────────────────────────────────────────────────────────────────────
# .env.production.example — Cloud deployment environment variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy relevant variables to each platform's env var settings.
# DO NOT commit the actual .env.production file to Git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase (PostgreSQL) ────────────────────────────────────────────────────
# Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# ── Upstash Redis ────────────────────────────────────────────────────────────
# Console → Your database → REST URL (use the rediss:// URL)
REDIS_URL=rediss://default:[password]@[endpoint].upstash.io:6379

# ── CloudAMQP (RabbitMQ) ────────────────────────────────────────────────────
# Dashboard → Your instance → AMQP URL
CLOUDAMQP_URL=amqps://[user]:[pass]@[host]/[vhost]

# ── Database credentials (still needed by Spring Boot alongside DATABASE_URL)
DB_USERNAME=postgres
DB_PASSWORD=your-supabase-db-password

# ── JWT Secret ───────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_USE_A_64_CHAR_RANDOM_STRING

# ── Internal API Key (shared between backend and AI service) ─────────────────
INTERNAL_API_KEY=generate-a-random-48-char-string

# ── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_API_KEY=your-gemini-api-key

# ── Email (SendGrid) ────────────────────────────────────────────────────────
MAIL_ENABLED=true
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=SG.your-sendgrid-api-key
MAIL_FROM=your-verified-sender@domain.com

# ── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ── CORS (set to your Vercel frontend URL) ───────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Frontend env vars (set in Vercel dashboard) ──────────────────────────────
API_BASE_URL=https://your-backend.up.railway.app
VITE_API_BASE_URL=https://your-backend.up.railway.app

# ── AI Service URL (set in Railway backend env) ─────────────────────────────
AI_SERVICE_URL=https://your-ai-service.onrender.com

# ── Grafana (only if self-hosting monitoring) ────────────────────────────────
GRAFANA_ADMIN_PASSWORD=your-grafana-password

# ── App settings ─────────────────────────────────────────────────────────────
APP_BASE_URL=https://your-app.vercel.app
